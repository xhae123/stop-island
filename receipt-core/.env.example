# 영수증 코어 서버(Go) 환경변수. 실제 .env는 노드에만(git 제외). 시크릿을 레포에 넣지 말 것.

# 리슨 포트(컨테이너 내부).
PORT=8000

# 소비자 API 키(콤마 구분). 운영에선 반드시 설정. 비우면 인증 비활성(dev 전용).
# 예: RECEIPT_CORE_API_KEYS=si-live-xxxxxxxx,other-svc-yyyyyyyy
RECEIPT_CORE_API_KEYS=

# fail-fast 동시성 상한. 초과 요청은 즉시 503 saturated.
RECEIPT_CORE_MAX_CONCURRENCY=8

# 엔진 호출 타임아웃(초). 실 Gemini 배선 시 HTTP 클라이언트 타임아웃으로 사용.
RECEIPT_CORE_TIMEOUT_SECONDS=8

# 실 Gemini 배선 전까지 mock 엔진 사용(1=mock, 0=실엔진). 실키 배선 후 0으로.
RECEIPT_CORE_MOCK=1

# 실 Gemini 배선용(현재 미사용).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
