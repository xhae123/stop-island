# 노드에 .env 로 복사해서 실제 값을 채운다 (이 예시 파일만 git 추적, .env 는 제외).
#
# 관리자 로그인 비밀번호 (필수)
ADMIN_PASSWORD=change-me

# 프론트(Vercel) 도메인. 콤마로 여러 개 가능.
# 예: https://stop-island.vercel.app,https://www.stop-island.app
CORS_ORIGINS=http://localhost:5173

# 영수증 OCR 자동 인증용 (선택 — 없으면 운영진 수동 확인 폴백)
GEMINI_API_KEY=

# 영수증 코어 서버 연동 (선택). 설정하면 OCR을 외부 코어(receipt-core)에 위임한다.
# 비우면 기존 인프로세스 Gemini seam을 그대로 쓴다(기본 동작 불변).
# 같은 노드 엣지 네트워크면 컨테이너명으로: http://receipt-core:8000
RECEIPT_CORE_URL=
RECEIPT_CORE_API_KEY=
RECEIPT_CORE_TIMEOUT_SECONDS=10
